{{- $pages := where site.RegularPages "Section" "blog" -}}
{{- if and (not .IsHome) (eq .Section "blog") -}}
  {{- $pages = .RegularPages -}}
{{- end -}}
{{- $limit := site.Config.Services.RSS.Limit -}}
{{- if ge $limit 1 -}}
  {{- $pages = first $limit $pages -}}
{{- end -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ if .IsHome }}{{ site.Title }}{{ else }}{{ .Title }} on {{ site.Title }}{{ end }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ if .IsHome }}Recent writings on {{ site.Title }}{{ else }}Recent content in {{ .Title }} on {{ site.Title }}{{ end }}</description>
    <generator>Hugo -- gohugo.io</generator>
    <language>{{ site.Language.LanguageCode }}</language>
    {{ with index ($pages.ByLastmod.Reverse) 0 }}
      <lastBuildDate>{{ .Lastmod.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    {{ end }}
    <atom:link href="{{ .Permalink }}index.xml" rel="self" type="application/rss+xml" />
    {{ range $pages.ByDate.Reverse }}
      <item>
        <title>{{ .Title }}</title>
        <link>{{ .Permalink }}</link>
        <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
        <guid>{{ .Permalink }}</guid>
        <description>{{ .Summary | plainify | htmlEscape }}</description>
      </item>
    {{ end }}
  </channel>
</rss>
